<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ObsidianScanner.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="960" d:DesignHeight="600"
        x:Class="ObsidianScanner.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="960" Height="600"
        Icon="/Assets/avalonia-logo.ico"
        Title="ObsidianScanner">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*,Auto" Margin="12">
        <DockPanel Grid.Row="0" Margin="0,0,0,10">
            <StackPanel DockPanel.Dock="Right"
                        VerticalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="12">
                <TextBlock VerticalAlignment="Center"
                           Opacity="0.65"
                           Text="{Binding LastRefreshedDisplay}" />
                <Button MinWidth="130"
                        Command="{Binding RefreshCommand}"
                        Content="Refresh" />
            </StackPanel>
            <TextBlock VerticalAlignment="Center"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Text="Plugins across Obsidian vaults" />
        </DockPanel>

        <Grid Grid.Row="1" ColumnDefinitions="280,16,*">
            <ListBox Grid.Column="0"
                     ItemsSource="{Binding Plugins}"
                     SelectedItem="{Binding SelectedPlugin}">
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:ObsidianPluginViewModel">
                        <TextBlock Text="{Binding ListTitle}" TextWrapping="Wrap" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Border Grid.Column="2"
                    Padding="12"
                    BorderBrush="#33888888"
                    BorderThickness="1"
                    CornerRadius="4">
                <Panel>
                    <TextBlock HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Opacity="0.55"
                               Text="Select a plugin to see each vault and enable or disable it."
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               IsVisible="{Binding NoSelectedPlugin}" />
                    <ScrollViewer IsVisible="{Binding HasSelectedPlugin}">
                        <StackPanel DataContext="{Binding SelectedPlugin}">
                            <TextBlock FontSize="16"
                                       FontWeight="SemiBold"
                                       Text="{Binding Name}"
                                       TextWrapping="Wrap" />
                            <TextBlock Margin="0,2,0,8"
                                       Opacity="0.75"
                                       Text="{Binding Id}"
                                       TextWrapping="Wrap" />
                            <TextBlock Margin="0,0,0,4"
                                       Text="{Binding Version}"
                                       TextWrapping="Wrap" />
                            <TextBlock Margin="0,0,0,8"
                                       Opacity="0.85"
                                       Text="{Binding Author}"
                                       TextWrapping="Wrap" />
                            <TextBlock Margin="0,0,0,12"
                                       Text="{Binding Description}"
                                       TextWrapping="Wrap" />

                            <TextBlock Margin="0,0,0,6"
                                       FontWeight="SemiBold"
                                       Text="Vaults" />

                            <Grid Margin="0,0,0,8" ColumnDefinitions="*,Auto">
                                <TextBox Grid.Column="0"
                                         MinWidth="200"
                                         Margin="0,0,12,0"
                                         Watermark="Search by word prefix (vault name or path)…"
                                         Text="{Binding VaultSearchText, Mode=TwoWay}" />
                                <Button Grid.Column="1"
                                        MinWidth="170"
                                        VerticalAlignment="Top"
                                        Command="{Binding ActivateSelectedCommand}"
                                        Content="Activate selected" />
                            </Grid>

                            <ItemsControl ItemsSource="{Binding FilteredVaultRows}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:VaultPluginRowViewModel">
                                        <Border Margin="0,0,0,8"
                                                Padding="10"
                                                BorderBrush="#22888888"
                                                BorderThickness="1"
                                                CornerRadius="4">
                                            <Grid ColumnDefinitions="Auto,*,Auto"
                                                  RowDefinitions="Auto,Auto,Auto,Auto">
                                                <CheckBox Grid.Row="0"
                                                          Grid.Column="0"
                                                          Margin="0,0,10,0"
                                                          VerticalAlignment="Top"
                                                          IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                          ToolTip.Tip="Include this vault when using Activate selected" />
                                                <StackPanel Grid.Row="0"
                                                            Grid.Column="1"
                                                            Spacing="4">
                                                    <TextBlock FontWeight="SemiBold"
                                                               Text="{Binding VaultDisplayName}"
                                                               TextWrapping="Wrap" />
                                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                                        <TextBlock Opacity="0.8"
                                                                   Text="{Binding IsInstalled, StringFormat='Installed: {0}'}" />
                                                        <TextBlock Opacity="0.8"
                                                                   Text="{Binding ListedInCommunityPlugins, StringFormat='Listed: {0}'}" />
                                                        <TextBlock Opacity="0.8"
                                                                   Text="{Binding IsPluginActiveInObsidian, StringFormat='Active in Obsidian: {0}'}" />
                                                    </StackPanel>
                                                    <TextBlock Opacity="0.72"
                                                               Text="{Binding VaultPath, StringFormat='Location: {0}'}"
                                                               TextWrapping="Wrap" />
                                                    <TextBlock Opacity="0.85"
                                                               Text="Restricted mode is on in this vault — plugins stay off in Obsidian until you disable Restricted mode in Settings → Community plugins."
                                                               TextWrapping="Wrap"
                                                               IsVisible="{Binding ShowRestrictedModeHint}" />
                                                </StackPanel>
                                                <StackPanel Grid.Row="0"
                                                            Grid.Column="2"
                                                            HorizontalAlignment="Right"
                                                            Orientation="Horizontal"
                                                            Spacing="8">
                                                    <Button MinWidth="88"
                                                            Command="{Binding ActivateCommand}"
                                                            Content="Activate"
                                                            IsEnabled="{Binding CanActivate}" />
                                                    <Button MinWidth="88"
                                                            Command="{Binding DeactivateCommand}"
                                                            Content="Deactivate"
                                                            IsEnabled="{Binding CanDeactivate}" />
                                                </StackPanel>
                                                <CheckBox Grid.Row="1"
                                                          Grid.Column="1"
                                                          Grid.ColumnSpan="2"
                                                          Margin="0,8,0,0"
                                                          Content="Import plugin data (data.json)"
                                                          IsChecked="{Binding ImportPluginData}"
                                                          IsVisible="{Binding ShowImportDataOption}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </Panel>
            </Border>
        </Grid>

        <TextBlock Grid.Row="2"
                   Margin="0,10,0,0"
                   Foreground="Crimson"
                   Text="{Binding LastError}"
                   TextWrapping="Wrap"
                   IsVisible="{Binding HasError}" />
    </Grid>
</Window>
